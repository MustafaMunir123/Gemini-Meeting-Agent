# --- Optional: access key gate (if set, app shows a key entry page before main UI) ---
# LOGIN_API_KEY=

# --- Attendee (optional; only if you use Attendee to launch bots) ---
ATTENDEE_API_KEY=your_attendee_api_key
ATTENDEE_API_BASE_URL=http://localhost:8000

# --- Zoom Meeting SDK (for minimal zoom-bot; also used by app UI to launch bot) ---
# Use the SAME SDK Key + Secret as Attendee (from Attendee project env or Zoom OAuth app). If you get "Invalid signature" (3712), copy these from where Attendee gets them—no extra spaces/newlines.
ZOOM_CLIENT_ID=your_zoom_meeting_sdk_client_id
ZOOM_CLIENT_SECRET=your_zoom_meeting_sdk_client_secret
# From March 2026, joining meetings outside your app's account may require OBF or ZAK. Set one if the bot cannot join:
# ZOOM_ZAK_TOKEN=   # Zoom App Key (ZAK) from your backend
# ZOOM_OBF_TOKEN=   # On-behalf-of token (or ZOOM_REGISTRANT_TOKEN). See https://developers.zoom.us/docs/meeting-sdk/obf-faq/
# Launch from UI: open app (e.g. http://localhost:3000), enter meeting URL, click "Launch meeting bot". Voice WS is on same server at /voice-ws.

# --- Single-port server (default: one process on PORT 3000, voice WS at /voice-ws) ---
# PORT=3000
# APP_URL=http://localhost:3000   # In production set to your app URL (e.g. https://your-app.com) so the bot uses wss://your-app.com/voice-ws
# VOICE_WS_PATH=/voice-ws          # WebSocket path (only used when running merged server)
# For standalone voice WS only: npm run voice-ws (uses VOICE_WS_PORT=3001)
# VOICE_WS_PORT=3001

# --- Voice agent wake word (server-side gate: only respond when user says one of these in the same message) ---
# WAKE_WORDS=gemini,sidekick,assistant,bot
# ZOOM_BOT_NAME=Gemini Sidekick   # Bot display name; its words are also used as wake words

# --- Gemini Live API ---
# From Google AI Studio: https://aistudio.google.com/ (API key).
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# --- Google Drive (for voice agent "search in drive" tool) ---
# Create OAuth 2.0 credentials in Google Cloud Console (Drive API enabled).
# Add authorized redirect URI: http://localhost:3000/api/auth/google/callback (or your app URL + /api/auth/google/callback)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
DRIVE_FOLDER_ID=your_drive_folder_id
# Optional: secret for internal drive-search calls from voice-ws server (recommended in production)
DRIVE_SEARCH_SECRET=
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_KEY=your_jira_api_token
# If you see "unable to get local issuer certificate" when calling Jira, set to 1 to skip TLS verification (dev only).
# JIRA_INSECURE_TLS=1
# For create Jira: required when creating top-level issues (no parent). Use your project key (e.g. from issue ST-123 → ST).
JIRA_PROJECT_KEY=ST
# Optional: to add new issues to the latest sprint. Board ID = number in board URL (e.g. .../boards/42 → 42), or GET https://YOUR_DOMAIN.atlassian.net/rest/agile/1.0/board
JIRA_BOARD_ID=