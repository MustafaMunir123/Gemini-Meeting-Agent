ATTENDEE_API_KEY=your_attendee_api_key
ATTENDEE_API_BASE_URL=http://localhost:8000

# --- Gemini Live API ---
# From Google AI Studio: https://aistudio.google.com/ (API key).
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# --- Google Drive (for voice agent "search in drive" tool) ---
# Create OAuth 2.0 credentials in Google Cloud Console (Drive API enabled).
# Add authorized redirect URI: http://localhost:3000/api/auth/google/callback (or your app URL + /api/auth/google/callback)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
DRIVE_FOLDER_ID=your_drive_folder_id
# Optional: secret for internal drive-search calls from voice-ws server (recommended in production)
DRIVE_SEARCH_SECRET=
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_KEY=your_jira_api_token